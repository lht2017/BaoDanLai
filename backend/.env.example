# ============================================
# 爆单来 BaoDanLai 后端环境配置
# 复制为 .env 后填写实际值
# ============================================

# 应用配置
APP_NAME=爆单来
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-secret-key

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=baodanlai
POSTGRES_PASSWORD=baodanlai_dev_2026
POSTGRES_DB=baodanlai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AI 服务（DeepSeek / OpenAI 兼容接口）
AI_API_KEY=your-ai-api-key
AI_API_BASE=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# 数据源
TUSHARE_TOKEN=your-tushare-token

# 爬虫配置
CRAWLER_REQUEST_DELAY=0.5

# 日志
LOG_LEVEL=INFO
